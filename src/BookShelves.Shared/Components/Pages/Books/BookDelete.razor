@code 
{
    [CascadingParameter] 
    IMudDialogInstance? MudDialog { get; set; } // = default!;

    [Parameter]
    public BookViewModel? BookObject { get; set; }

    private void Ok() => MudDialog? .Close(DialogResult.Ok(BookObject?.IdValue));
    private void Close() => MudDialog?.Close(DialogResult.Cancel());
    private void Cancel() => MudDialog?.Cancel();
}