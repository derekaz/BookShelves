@page "/authentication/login"
@using BookShelves.Shared.Services.ServiceInterfaces

@inject NavigationManager Navigation
@inject IExternalAuthenticationStateProvider AuthStateProvider

@code {
    protected override async Task OnInitializedAsync()
    {
        var temp = await AuthStateProvider.GetAuthenticationStateAsync();
        if (temp == null || temp.User.Identity == null || temp.User.Identity.IsAuthenticated == false)
        {
            await AuthStateProvider.LogInAsync(); //.Wait();
        };

        await base.OnInitializedAsync();
    }

